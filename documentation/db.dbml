// Схема БД Restaurant Management System
// Синхронизировано с backend: Flyway migrations V1–V7 (ветка employee, commit 205d958)

Table users {
  id integer [primary key, increment, note: 'BIGSERIAL']
  login varchar(16) [unique, not null, note: '4–16 символов']
  password_hash varchar(255) [not null]
  user_type varchar(20) [not null, note: 'CLIENT | EMPLOYEE']
}

Table roles {
  id integer [primary key, increment]
  name varchar(50) [unique, not null, note: 'ADMIN | MANAGER | COURIER']
}

Table avatars {
  id integer [primary key, increment]
  path varchar(500) [not null]
}

Table employees {
  user_id integer [primary key, ref: > users.id]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  middle_name varchar(100)
  role_id integer [not null, ref: > roles.id]
  phone varchar(20) [not null]
  avatar_id integer [ref: > avatars.id]
  is_working boolean [not null, default: false]
}

Table clients {
  user_id integer [primary key, ref: > users.id]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  middle_name varchar(100)
  email varchar(255) [unique, not null]
  phone varchar(20) [not null]
  avatar_id integer [ref: > avatars.id]
}

Table client_addresses {
  id integer [primary key, increment]
  client_id integer [not null, ref: > clients.user_id]
  address_text text [not null]
}

Table dishes {
  id integer [primary key, increment]
  name varchar(255) [not null]
  weight float [not null]
  calories integer [not null]
  price decimal(10,2) [not null]
  description text
}

Table photos {
  id integer [primary key, increment]
  path varchar(500) [not null]
}

Table dish_photos {
  dish_id integer [not null, ref: > dishes.id]
  photo_id integer [not null, ref: > photos.id]
  indexes {
    (dish_id, photo_id) [pk]
  }
}

Table menus {
  id integer [primary key, increment]
  name varchar(255) [not null]
  seasonality varchar(50) [not null]
  is_active boolean [not null, default: false]
}

Table menu_dishes {
  menu_id integer [not null, ref: > menus.id]
  dish_id integer [not null, ref: > dishes.id]
  indexes {
    (menu_id, dish_id) [pk]
  }
}

Table ingredients {
  id integer [primary key, increment]
  name varchar(255) [unique, not null]
}

Table dish_ingredients {
  dish_id integer [not null, ref: > dishes.id]
  ingredient_id integer [not null, ref: > ingredients.id]
  indexes {
    (dish_id, ingredient_id) [pk]
  }
}

Table order_statuses {
  id integer [primary key, increment]
  status_name varchar(50) [unique, not null, note: 'NEW | COOKING | DELIVERING | DELIVERED | CANCELLED']
}

Table orders {
  id integer [primary key, increment]
  client_id integer [not null, ref: > clients.user_id]
  address_id integer [not null, ref: > client_addresses.id]
  manager_id integer [ref: > employees.user_id]
  courier_id integer [ref: > employees.user_id]
  total_price decimal(12,2) [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
}

Table order_status_history {
  id integer [primary key, increment]
  order_id integer [not null, ref: > orders.id]
  status_id integer [not null, ref: > order_statuses.id]
  employee_id integer [ref: > employees.user_id]
  client_id integer [ref: > clients.user_id]
  comment text
  changed_at timestamptz [not null, default: `now()`]
}

Table order_items {
  id integer [primary key, increment]
  order_id integer [not null, ref: > orders.id]
  dish_id integer [not null, ref: > dishes.id]
  quantity integer [not null, note: '> 0']
  price_at_moment decimal(10,2) [not null]
}
